# Security-focused .gitignore template
# Add these patterns to your project's .gitignore

# Environment secrets (NEVER commit)
.env
.env.*
!.env.example
!.env.template

# API keys and credentials
config.json
credentials.json
credentials.*
secrets.*
*.key
*.pem
*.p12
*.pfx
*.cert

# Agent configurations with secrets
.claude/config.json
.claude/*.jsonl
.claude/history.jsonl
.claude/stats-cache.json
.agent/credentials.*
.agent/secrets.*

# IDE settings that may contain paths/tokens
.vscode/settings.json
.idea/workspace.xml
.idea/tasks.xml

# OS-specific
.DS_Store
Thumbs.db
Desktop.ini
*~
