#!/usr/bin/env bash
# Post-commit hook: Memory Bank Update Reminder
# Reminds developer to update Memory Bank after significant commits
#
# Installation:
#   ~/.agent_global/hooks/install-mb-hook.sh <project-path>

# Skip if in rebase/merge/cherry-pick
if [ -d "$(git rev-parse --git-dir)/rebase-merge" ] || \
   [ -f "$(git rev-parse --git-dir)/MERGE_HEAD" ] || \
   [ -f "$(git rev-parse --git-dir)/CHERRY_PICK_HEAD" ]; then
    exit 0
fi

# Get commit info
COMMIT_MSG=$(git log -1 --pretty=%B)
COMMIT_TYPE=$(echo "$COMMIT_MSG" | grep -oE "^[a-z]+")
CHANGED_FILES=$(git diff HEAD~1 --name-only 2>/dev/null | wc -l)
INSERTIONS=$(git diff HEAD~1 --stat | tail -1 | grep -oE "[0-9]+ insertion" | grep -oE "[0-9]+" || echo "0")
DELETIONS=$(git diff HEAD~1 --stat | tail -1 | grep -oE "[0-9]+ deletion" | grep -oE "[0-9]+" || echo "0")

# Calculate significance score
SIGNIFICANCE=0

# Type-based scoring
case "$COMMIT_TYPE" in
    feat|refactor|perf)
        SIGNIFICANCE=$((SIGNIFICANCE + 3))
        ;;
    fix)
        SIGNIFICANCE=$((SIGNIFICANCE + 2))
        ;;
    docs|style|test)
        SIGNIFICANCE=$((SIGNIFICANCE + 1))
        ;;
esac

# Size-based scoring
if [ "$CHANGED_FILES" -gt 10 ]; then
    SIGNIFICANCE=$((SIGNIFICANCE + 3))
elif [ "$CHANGED_FILES" -gt 5 ]; then
    SIGNIFICANCE=$((SIGNIFICANCE + 2))
fi

if [ "$INSERTIONS" -gt 200 ]; then
    SIGNIFICANCE=$((SIGNIFICANCE + 2))
fi

# Check for BREAKING CHANGE
if echo "$COMMIT_MSG" | grep -qE "BREAKING CHANGE|^[a-z]+!:"; then
    SIGNIFICANCE=$((SIGNIFICANCE + 5))
fi

# Only show reminder if significance >= 4 (significant change)
if [ "$SIGNIFICANCE" -ge 4 ]; then
    echo ""
    echo "╔════════════════════════════════════════════════════════════╗"
    echo "║  📝 MEMORY BANK UPDATE REMINDER                            ║"
    echo "╚════════════════════════════════════════════════════════════╝"
    echo ""
    echo "  Significant change detected:"
    echo "  • Type: $COMMIT_TYPE"
    echo "  • Files changed: $CHANGED_FILES"
    echo "  • Lines: +$INSERTIONS/-$DELETIONS"
    echo ""
    echo "  Consider updating Memory Bank:"

    # Suggest specific files based on commit type
    case "$COMMIT_TYPE" in
        feat|refactor|perf|fix)
            echo "  • context.md — Update recent changes & active workstreams"
            if [ "$COMMIT_TYPE" = "refactor" ] || [ "$COMMIT_TYPE" = "perf" ]; then
                echo "  • architecture.md — Document structural changes"
            fi
            ;;
        docs)
            echo "  • context.md — Note documentation updates"
            ;;
    esac

    # Show quick command
    if [ -d ".memory-bank" ]; then
        echo ""
        echo "  Quick edit: mbc  (or run 'mbk' for full Memory Bank)"
    fi

    echo ""
    echo "  Why? Keeps context fresh for Claude, Kilo & Antigravity"
    echo ""
fi

exit 0
