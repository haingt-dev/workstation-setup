#!/bin/bash
# Wrapper for lazygit in dashboard pane.
# Reads target directory from /tmp/kitty-main-cwd (written by chpwd hook).
# When lazygit quits, re-reads the file and restarts in the new directory.

CWD_FILE="/tmp/kitty-main-cwd"
POLL_INTERVAL=2

while true; do
    dir=$(cat "$CWD_FILE" 2>/dev/null)
    [[ -z "$dir" || ! -d "$dir" ]] && dir="$HOME"
    cd "$dir" 2>/dev/null || cd "$HOME"

    if git rev-parse --git-dir &>/dev/null 2>&1; then
        lazygit
    else
        clear
        printf '\n  \e[38;2;137;180;250m\e[0m  \e[2m%s\e[0m\n' "$dir"
        printf '  \e[2mNot a git repo — waiting for cd...\e[0m\n'
        # Poll until directory changes or becomes a git repo
        last_dir="$dir"
        while true; do
            sleep "$POLL_INTERVAL"
            new_dir=$(cat "$CWD_FILE" 2>/dev/null)
            [[ -z "$new_dir" ]] && continue
            [[ "$new_dir" != "$last_dir" ]] && break
        done
    fi
done
