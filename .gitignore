*.deb
.chromium-browser-snapshots/

# VS Code project settings
.vscode/

# Tool-managed state — captured by the backup bundle, NEVER vendored in this repo.
# assets/.claude + assets/vscode were the source of a real secret leak in git
# history (purged 2026-05-29). Keep these ignored permanently.
assets/.claude/
assets/vscode/
assets/.config/Code/
assets/godot/
assets/fonts/
assets/.agent_global/

# Environment secrets (NEVER commit)
.env
.env.*
!.env.example
!.env.template

# API keys and credentials
config.json
credentials.json
credentials.*
secrets.*
*.key
*.pem
*.p12
*.pfx

# Agent credentials
.agent/credentials.*
.agent/secrets.*
